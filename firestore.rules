rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ID Poisioning prevention
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Email verified check. Checks if email is verified or logged in through trusted Google Provider
    function isVerifiedUser() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Schema Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'photoURL'])
        && data.uid is string
        && data.name is string;
    }

    function isValidAlbum(data) {
      return data.keys().hasAll(['userId', 'ownedStickers', 'repeatedStickers', 'lastUpdated', 'progressPercent'])
        && data.keys().size() == 5
        && data.userId is string
        && data.userId.size() <= 128
        && data.ownedStickers is list
        && data.ownedStickers.size() <= 1000
        && data.repeatedStickers is list
        && data.repeatedStickers.size() <= 1000
        && data.lastUpdated == request.time
        && data.progressPercent is number
        && data.progressPercent >= 0
        && data.progressPercent <= 100;
    }

    function isValidTradeShare(data) {
      return data.keys().hasAll(['shareId', 'userId', 'expiresAt', 'isPublic'])
        && data.keys().size() == 4
        && data.shareId is string
        && data.shareId.size() <= 128
        && data.userId is string
        && data.userId.size() <= 128
        && data.expiresAt is timestamp
        && data.isPublic is bool;
    }

    function isValidActivityLog(data) {
      return data.keys().hasAll(['userId', 'type', 'timestamp'])
        && data.userId is string
        && data.userId.size() <= 128
        && data.type is string
        && (data.type == 'stickers_added' || data.type == 'milestone' || data.type == 'trade' || data.type == 'progress_recovery')
        && data.timestamp == request.time;
    }

    // Match definitions
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && isVerifiedUser();
      allow update: if isOwner(userId) && isVerifiedUser();
      allow delete: if isOwner(userId);

      // Subcollection for stickers (only the owner can read and write)
      match /stickers/{stickerId} {
        allow read: if isOwner(userId) && isValidId(stickerId);
        allow write: if isOwner(userId) && isValidId(stickerId)
          && incoming().ownedCount is int
          && incoming().ownedCount >= 0
          && incoming().stickerId == stickerId;
      }

      // Subcollection for pageScans (only the owner can write/read page completion status)
      match /pageScans/{pageId} {
        allow read: if isOwner(userId) && isValidId(pageId);
        allow create: if isOwner(userId) && isValidId(pageId);
        allow update: if isOwner(userId) && isValidId(pageId)
          && (existing().status != "completed" || incoming().status == "completed");
        allow delete: if false;
      }

      match /settings/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /friends/{docId} {
        allow read, write: if isOwner(userId);
      }

      // Subcollection for user activity logs
      match /activity/{activityId} {
        allow read: if isOwner(userId) && isValidId(activityId);
        allow write: if isOwner(userId) && isValidId(activityId);
      }
    }

    match /trade_shares/{shareId} {
      allow read: if isSignedIn() && (
        resource.data.ownerUid == request.auth.uid || 
        (resource.data.isPublic == true && resource.data.expiresAt > request.time)
      );
      allow create: if isSignedIn() && incoming().ownerUid == request.auth.uid && isVerifiedUser() && isValidId(shareId);
      allow update: if isSignedIn() && existing().ownerUid == request.auth.uid && incoming().ownerUid == request.auth.uid && isVerifiedUser() && isValidId(shareId);
      allow delete: if isSignedIn() && existing().ownerUid == request.auth.uid && isValidId(shareId);
    }

    match /activity_logs/{logId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid && isValidId(logId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isVerifiedUser() && isValidId(logId) && isValidActivityLog(incoming());
      allow update, delete: if false;
    }
  }
}
